# Dependencies (rebuilt inside Docker)
node_modules/

# Local SQLite database (Railway has its own volume)
data/
*.db
*.db-wal
*.db-shm

# Git history (not needed in image)
.git/
.gitignore

# Dev/config files not needed at runtime
nixpacks.toml
railway.toml
Dockerfile
.dockerignore
*.md
docs/
scripts/

# OS files
.DS_Store
Thumbs.db

# Environment files (secrets injected via Railway env vars)
.env
.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
